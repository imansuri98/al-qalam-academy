# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres_password@db:5432/alqalam"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres_password"
POSTGRES_DB="alqalam"

# NextAuth Configuration
# Run `openssl rand -base64 32` or generate a random key to set this in .env
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Sanity Configuration
# Find these in your Sanity.io Manage dashboard
NEXT_PUBLIC_SANITY_PROJECT_ID="your_sanity_project_id_here"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-03-19"
# Token with Editor or Write access if you want the frontend/API to publish data,
# but public read client is sufficient for basic querying.
SANITY_API_READ_TOKEN=""
